# ─── Required ─────────────────────────────────────────────────────────────────

# Anthropic API key — obtain at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Claude model to use for product analysis and chat.
# Recommended: claude-sonnet-4-6  (fast, high quality)
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── Vercel Blob (required for Vercel deployments) ────────────────────────────

# Token for @vercel/blob — create a Blob store in your Vercel project under
# Storage → Create → Blob, then copy the BLOB_READ_WRITE_TOKEN here.
# Only required when deploying to Vercel. Omit for local development.
BLOB_READ_WRITE_TOKEN=

# ─── Optional — remote asset APIs ─────────────────────────────────────────────

# Pexels API key for fetching high-quality lifestyle background videos.
# When absent, local files from public/assets/backgrounds/ are used instead.
# Sign up at https://www.pexels.com/api/
PEXELS_API_KEY=

# Giphy API key for fetching reaction GIFs matched to the product category.
# When absent, local files from public/assets/gifs/ are used instead.
# Sign up at https://developers.giphy.com/
GIPHY_API_KEY=

# ─── Optional — FFmpeg override ───────────────────────────────────────────────

# Absolute path to a custom FFmpeg binary. Leave empty to use the bundled
# ffmpeg-static binary (recommended for Vercel and Docker).
FFMPEG_PATH=
